<?xml version="1.0" encoding="utf-8"?>
<!--
  =============================================================================
  AndroidManifest.xml
  =============================================================================
  This is the core configuration file for the Android application.
  It declares:
  - App components (Activities, Services)
  - Required permissions
  - Intent filters (for OAuth interception)
  - Hardware/software requirements
  
  IMPORTANT: Every Android app MUST have this file.
  =============================================================================
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.kilo.companion"
    android:versionCode="1"
    android:versionName="1.0.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <!-- ========================================================================= -->
    <!-- PERMISSIONS -->
    <!-- ========================================================================= -->
    <!-- Permissions tell Android what system resources the app needs access to. -->
    <!-- Users must grant these permissions for the app to function properly. -->
    <!-- ========================================================================= -->


    <!-- Internet access - required for WebView and OAuth flows -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Network state - allows checking if network is available -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage permissions for Android 10 (API 29) and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- For Android 11+ (API 30+), we need MANAGE_EXTERNAL_STORAGE for broad access -->
    <!-- This is required to access Documents/KiloWorkspace directory -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- Access to all files on Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <permission
        android:name="com.kilo.companion.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.kilo.companion.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" /> <!-- ========================================================================= -->
    <!-- APPLICATION DECLARATION -->
    <!-- ========================================================================= -->
    <application
        android:name="com.kilo.companion.KiloCompanionApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KiloCompanion" >

        <!-- ===================================================================== -->
        <!-- MAIN ACTIVITY -->
        <!-- ===================================================================== -->
        <!-- This is the entry point of the app - what users see when they tap -->
        <!-- the app icon. It hosts all the Compose UI screens via navigation. -->
        <!-- ===================================================================== -->
        <activity
            android:name="com.kilo.companion.MainActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize"
            android:exported="true"
            android:theme="@style/Theme.KiloCompanion" >

            <!-- Main launcher intent - this makes the app appear in the launcher -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===================================================================== -->
        <!-- AUTH HANDLER ACTIVITY -->
        <!-- ===================================================================== -->
        <!-- This activity intercepts OAuth redirect URLs from authentication -->
        <!-- flows. It handles custom URI schemes (opencode://auth) and localhost -->
        <!-- callbacks that the CLI tools use for authentication. -->
        <!-- ===================================================================== -->
        <activity
            android:name="com.kilo.companion.AuthHandlerActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:theme="@style/Theme.KiloCompanion.NoActionBar" >

            <!-- Intent filter for OpenCode custom URI scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="auth"
                    android:scheme="opencode" />
            </intent-filter>

            <!-- Intent filter for Kilo custom URI scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="auth"
                    android:scheme="kilo" />
            </intent-filter>

            <!-- Intent filter for localhost callbacks on various ports -->
            <!-- CLI tools often listen on localhost:PORT for OAuth callbacks -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="127.0.0.1"
                    android:scheme="http" />
                <data
                    android:host="localhost"
                    android:scheme="http" />
            </intent-filter>

            <!-- HTTPS localhost variants -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="127.0.0.1"
                    android:scheme="https" />
                <data
                    android:host="localhost"
                    android:scheme="https" />
            </intent-filter>

            <!-- GitHub OAuth callback handler -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="oauth"
                    android:scheme="com.kilo.companion" />
            </intent-filter>
        </activity>

        <!-- ===================================================================== -->
        <!-- FILE PROVIDER -->
        <!-- ===================================================================== -->
        <!-- FileProvider is used to safely share files with other apps via URIs. -->
        <!-- Required for Android 7.0+ when sharing files with external apps. -->
        <!-- ===================================================================== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.kilo.companion.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true" >
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name="androidx.activity.ComponentActivity"
            android:exported="true" />
        <activity
            android:name="androidx.compose.ui.tooling.PreviewActivity"
            android:exported="true" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.kilo.companion.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>